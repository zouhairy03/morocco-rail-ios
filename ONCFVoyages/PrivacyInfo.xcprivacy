<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- The app does not track users across apps/websites owned by other companies. -->
    <key>NSPrivacyTracking</key>
    <false/>
    <key>NSPrivacyTrackingDomains</key>
    <array/>

    <!-- No data is transmitted off device today (mock backend). When a real
         ONCF API / payment processor / auth backend is connected, declare the
         collected data types here (e.g. Email, Name, Payment Info). -->
    <key>NSPrivacyCollectedDataTypes</key>
    <array/>

    <!-- Required-reason APIs actually used by the app. -->
    <key>NSPrivacyAccessedAPITypes</key>
    <array>
        <dict>
            <!-- @AppStorage / UserDefaults for preferences (language, lock,
                 reminder lead-time, service-alerts toggle). -->
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryUserDefaults</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <string>CA92.1</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
